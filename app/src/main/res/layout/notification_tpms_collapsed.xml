<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_fl_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FL"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_fl_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_fr_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FR"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_fr_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_rl_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RL"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_rl_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_rr_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RR"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_rr_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/notif_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:text="PSI"
        android:textSize="10sp" />

</LinearLayout>
