<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/notif_expanded_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_expanded_fl_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FL"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_expanded_fl_pressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/notif_expanded_fl_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_indicator_empty" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_expanded_fr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FR"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_expanded_fr_pressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/notif_expanded_fr_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_indicator_empty" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_expanded_rl_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RL"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_expanded_rl_pressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/notif_expanded_rl_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_indicator_empty" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_expanded_rr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RR"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_expanded_rr_pressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/notif_expanded_rr_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_indicator_empty" />
        </LinearLayout>

        <TextView
            android:id="@+id/notif_expanded_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:text="PSI"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
