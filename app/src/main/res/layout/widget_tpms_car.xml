<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:paddingBottom="4dp"
        android:text="Offline"
        android:textColor="#8FA3BC"
        android:textSize="11sp" />

    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:padding="4dp">

        <ImageView
            android:id="@+id/widget_car"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/widget_car_content_description"
            android:scaleType="fitCenter"
            android:src="@drawable/auto" />
    </FrameLayout>

    <!-- FL -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="22dp"
        android:background="@drawable/widget_wheel_card_bg"
        android:gravity="center"
        android:minWidth="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/widget_fl_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FL"
            android:textColor="#8FA3BC"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_fl_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#E8EDF4"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_fl_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_fl_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/widget_fl_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="3dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_indicator_empty" />
    </LinearLayout>

    <!-- FR -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="22dp"
        android:background="@drawable/widget_wheel_card_bg"
        android:gravity="center"
        android:minWidth="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/widget_fr_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FR"
            android:textColor="#8FA3BC"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_fr_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#E8EDF4"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_fr_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_fr_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/widget_fr_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="3dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_indicator_empty" />
    </LinearLayout>

    <!-- RL -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_wheel_card_bg"
        android:gravity="center"
        android:minWidth="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/widget_rl_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RL"
            android:textColor="#8FA3BC"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_rl_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#E8EDF4"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_rl_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_rl_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/widget_rl_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="3dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_indicator_empty" />
    </LinearLayout>

    <!-- RR -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_wheel_card_bg"
        android:gravity="center"
        android:minWidth="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/widget_rr_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RR"
            android:textColor="#8FA3BC"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_rr_pressure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#E8EDF4"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_rr_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_rr_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#8FA3BC"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/widget_rr_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="3dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_indicator_empty" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:text="PSI"
        android:textColor="#8FA3BC"
        android:textSize="10sp" />

</FrameLayout>
