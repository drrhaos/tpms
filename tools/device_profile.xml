<d:device xmlns:d="http://schemas.android.com/sdk/devices/1">
    <d:name>Teyes CC3</d:name>
    <d:id>teyes_cc3</d:id>
    <d:manufacturer>Teyes</d:manufacturer>
    <d:meta/>
    <d:hardware>
        <d:screen>
            <d:screenSize>7.0</d:screenSize>
            <d:resolution>1280x720</d:resolution>
            <d:xdpi>213.0</d:xdpi>
            <d:ydpi>213.0</d:ydpi>
            <d:diagonalLength>7.0</d:diagonalLength>
            <d:pixelDensity>hdpi</d:pixelDensity>
            <d:screenRatio>notlong</d:screenRatio>
            <d:screenSizeClass>large</d:screenSizeClass>
            <d:hasSoftwareButtons>true</d:hasSoftwareButtons>
            <d:hasFakeShutdown>true</d:hasFakeShutdown>
            <d:hasHardwareKeyboard>false</d:hasHardwareKeyboard>
        </d:screen>
        <d:networking>
            <d:networkingSpeed>full</d:networkingSpeed>
            <d:networkingDelay>none</d:networkingDelay>
        </d:networking>
        <d:ram>
            <d:ramSize>2048</d:ramSize>
        </d:ram>
        <d:storage>
            <d:sdCardSize>0</d:sdCardSize>
            <d:diskSize>8192</d:diskSize>
        </d:storage>
        <d:power>
            <d:batteryCapacity>10000</d:batteryCapacity>
        </d:power>
        <d:mic>
            <d:hasMic>no</d:hasMic>
        </d:mic>
        <d:camera>
            <d:autofocus>false</d:autofocus>
            <d:flash>false</d:flash>
        </d:camera>
        <d:sensors>
            <d:accelerometer>true</d:accelerometer>
            <d:gyroscope>false</d:gyroscope>
            <d:compass>false</d:compass>
            <d:proximity>false</d:proximity>
            <d:light>false</d:light>
            <d:barometer>false</d:barometer>
            <d:heartRate>false</d:heartRate>
            <d:eCompass>false</d:eCompass>
            <d:humidity>false</d:humidity>
            <d:pressure>true</d:pressure>
            <d:ambientTemperature>true</d:ambientTemperature>
        </d:sensors>
        <d:deviceCategory>automotive</d:deviceCategory>
        <d:hasMultipleScreens>false</d:hasMultipleScreens>
    </d:hardware>
    <d:state default="true" name="Landscape">
        <d:description>Landscape (default for car head unit)</d:description>
        <d:screenOrientation>landscape</d:screenOrientation>
        <d:keyboardState>none</d:keyboardState>
        <d:navState>none</d:navState>
        <d:lidState>none</d:lidState>
    </d:state>
    <d:state name="Portrait">
        <d:description>Portrait</d:description>
        <d:screenOrientation>portrait</d:screenOrientation>
        <d:keyboardState>none</d:keyboardState>
        <d:navState>none</d:navState>
        <d:lidState>none</d:lidState>
    </d:state>
</d:device>
